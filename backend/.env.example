# =============================================
# FPT Startup Platform - Backend Environment
# =============================================

PORT=5000
NODE_ENV=development

# MongoDB URI
# Local:  mongodb://localhost:27017/fpt_startup_db
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/fpt_startup_db
MONGODB_URI=mongodb://localhost:27017/fpt_startup_db

# JWT
JWT_SECRET=fpt_startup_super_secret_jwt_key_2024_change_in_prod
JWT_EXPIRES_IN=7d

# OpenAI (để trống nếu dùng mock AI)
OPENAI_API_KEY=

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Gemini AI
# Default model: gemini-2.5-flash
# If you get 404, check available models in Google AI Studio
# If you get 429, you might need to enable billing or check quota
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
